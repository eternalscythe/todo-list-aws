pipeline {
    agent none
    parameters {
        string(name: 'ENVIRONMENT', defaultValue: 'staging', description: 'staging o production')
        string(name: 'BRANCH', defaultValue: 'develop', description: 'Rama a construir')
    }
    stages {
      stage('Get Code') {
        agent { label 'default' }
            steps {
                checkout scm
                sh "git checkout ${params.BRANCH}"
                script {
                    // Determinar la rama del repositorio de configuración según el entorno
                    def configBranch = (params.ENVIRONMENT == 'staging') ? 'staging' : 'production'
                    // Descargar el archivo samconfig.toml (repositorio público)
                    sh "curl -s -o samconfig.toml https://raw.githubusercontent.com/eternalscythe/todo-list-aws-config/${configBranch}/samconfig.toml"
                }
                stash name: 'source', includes: '**/*'
            }
        }
       stage('Static Test') {
            agent { label 'static-test' }
            environment {
                ENV_UPPER = "${params.ENVIRONMENT.toUpperCase()}"
            }
            steps {
                script { unstash 'source' }
                sh '''#!/bin/bash
                    echo "Ejecutando en agente: $(hostname) - Usuario: $(whoami)"
                    # Activar virtualenv o crearlo si no existe
                    if [ -f todo-list-aws/bin/activate ]; then
                        . todo-list-aws/bin/activate
                    else
                        echo "Creando virtualenv"
                        bash pipelines/PIPELINE-FULL-${ENV_UPPER}/setup.sh
                    fi
                    bash pipelines/PIPELINE-FULL-${ENV_UPPER}/static_test.sh
                '''
            }
        }
        stage('Build') {
            agent { label 'default' }
            steps {
                script { unstash 'source' }
                sh "bash pipelines/common-steps/build.sh"
            }
        }
        stage('Deploy') {
            agent { label 'default' }
            steps {
                script { unstash 'source' }
                sh "bash pipelines/common-steps/deploy.sh ${params.ENVIRONMENT}"
                script {
                    def baseUrl = sh(script: "aws cloudformation describe-stacks --stack-name todo-list-aws-${params.ENVIRONMENT} --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text", returnStdout: true).trim()
                    writeFile file: 'api_url.txt', text: baseUrl
                    stash name: 'api-url', includes: 'api_url.txt'
                }
            }
        }
       stage('Integration Test') {
            agent { label 'integration-test' }
            environment {
                ENV_UPPER = "${params.ENVIRONMENT.toUpperCase()}"
            }
            steps {
                script {
                    unstash 'source'
                    unstash 'api-url'
                    def baseUrl = readFile('api_url.txt').trim()
                    sh """
                        #!/bin/bash
                        set -e
                        echo "Ejecutando en agente: \$(hostname) - Usuario: \$(whoami)"
                        # Crear virtualenv si no existe
                        if [ ! -f todo-list-aws/bin/activate ]; then
                            echo "Creando virtualenv"
                            bash pipelines/PIPELINE-FULL-${ENV_UPPER}/setup.sh
                        fi
                        # Ejecutar pruebas (integration.sh ya activa el virtualenv)
                        bash pipelines/common-steps/integration.sh ${baseUrl} ${params.ENVIRONMENT == 'production' ? 'readonly' : 'full'}
                    """
                }
            }
        }
        stage('Promote') {
            when { expression { params.ENVIRONMENT == 'staging' } }
            agent { label 'default' }
            steps {
                script { unstash 'source' }
                withCredentials([usernamePassword(credentialsId: 'github-token',
                                                  passwordVariable: 'GITHUB_TOKEN',
                                                  usernameVariable: 'GITHUB_USER')]) {
                    sh '''
                        git config user.email "jenkins@example.com"
                        git config user.name "Jenkins"
                        git reset --hard HEAD
                        git checkout master
                        git pull origin master
                        git merge develop --no-ff -m "Merge develop into master after successful CI [skip ci]"
                        git push https://${GITHUB_TOKEN}@github.com/eternalscythe/todo-list-aws.git master
                    '''
 1               }
            }
        }
    post {
        always {
            echo 'Pipeline finished'   // Eliminamos cleanWs
        }
    }
}
